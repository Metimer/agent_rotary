# agent_rotary — configuration des providers (v1)
# Copier ce fichier en .env et renseigner les clés souhaitées.
# Un provider n'est enregistré que si sa variable d'environnement est présente.

# Anthropic (Claude) — header x-api-key
ANTHROPIC_API_KEY=

# Moonshot AI (Kimi) — OpenAI-compatible, Bearer
MOONSHOT_API_KEY=

# OpenAI (Codex / GPT) — OpenAI-compatible, Bearer
OPENAI_API_KEY=
